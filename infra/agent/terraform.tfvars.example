# Copy to `terraform.tfvars` (gitignored) or pass with -var-file / -var flags.
project_id = "your-gcp-project-id"
region     = "us-central1"

# Required per-agent settings:
agent_id = "my-expert"
image    = "us-central1-docker.pkg.dev/your-gcp-project-id/expert-agent/backend:v0.1.0"

# Optional overrides:
# min_instances     = 0
# max_instances     = 10
# cpu               = "1"
# memory            = "1Gi"
# cache_ttl_seconds = 21600   # 6h; bump to 86400 for 24/7 usage patterns
# admin_key_secret_name = "admin-key-my-expert"
